{
  "name": "picodb",
  "version": "1.0.0",
  "description": "A purely JavaScript database, built for effectively storing data on your backend",
  "keywords": [
    "database"
  ],
  "scripts": {},
  "homepage": "https://github.com/jacob-hackney/picodb#readme",
  "bugs": {
    "url": "https://github.com/jacob-hackney/picodb/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-hackney/picodb.git"
  },
  "license": "Apache-2.0",
  "author": "Jacob Hackney",
  "type": "module",
  "main": "./lib/index.js",
  "bin": "./lib/cli/index.js",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./types/index.d.ts"
    },
    "./*": {
      "import": "./lib/*.js",
      "types": "./types/*.d.ts"
    }
  },
  "files": [
    "./lib",
    "./types",
    "./README.md",
    "./CHANGELOG.md"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3"
  }
}
